{
  "name": "@flaming-codes/sveltekit-runelayer",
  "version": "0.2.0",
  "description": "A CMS-as-a-package for SvelteKit apps — handles admin routes, storage, db, schemas, types, and auth.",
  "keywords": [
    "better-auth",
    "cms",
    "drizzle",
    "headless-cms",
    "svelte",
    "sveltekit"
  ],
  "homepage": "https://github.com/flaming-codes/sveltekit-runelayer#readme",
  "bugs": {
    "url": "https://github.com/flaming-codes/sveltekit-runelayer/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flaming-codes/sveltekit-runelayer.git"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "svelte": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./drizzle": {
      "types": "./src/db/drizzle-kit.ts",
      "default": "./src/db/drizzle-kit.ts"
    },
    "./admin": {
      "types": "./src/admin/index.ts",
      "svelte": "./src/admin/index.ts",
      "default": "./src/admin/index.ts"
    },
    "./admin/styles/*": "./src/admin/styles/*",
    "./sveltekit": {
      "types": "./src/sveltekit/index.ts",
      "svelte": "./src/sveltekit/index.ts",
      "default": "./src/sveltekit/index.ts"
    },
    "./sveltekit/server": {
      "types": "./src/sveltekit/server.ts",
      "default": "./src/sveltekit/server.ts"
    },
    "./sveltekit/components": {
      "types": "./src/sveltekit/components.ts",
      "svelte": "./src/sveltekit/components.ts",
      "default": "./src/sveltekit/components.ts"
    },
    "./sveltekit/drizzle": {
      "types": "./src/sveltekit/drizzle-config.ts",
      "default": "./src/sveltekit/drizzle-config.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@libsql/client": "catalog:",
    "better-auth": "catalog:",
    "carbon-components-svelte": "catalog:",
    "carbon-icons-svelte": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@sveltejs/kit": "catalog:",
    "drizzle-kit": "catalog:",
    "svelte": "catalog:",
    "testcontainers": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
